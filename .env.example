# Copy this file to .env and fill in your values.
# Do not commit .env (it is gitignored).
#
# Local profile (mvn spring-boot:run): application-local.properties imports project-root .env via spring.config.import.
# Other runtimes: set USDA_API_KEY, OPENAI_API_KEY, etc. in your deployment environment or IDE.

# ----- Local API test user (scripts only — not Spring properties) -----
AI_QA_USER=your-test-user
AI_QA_PASS=your-test-password

# ----- Database -----
# DB_USERNAME=root
# DB_PASSWORD=your_db_password

# ----- JWT -----
# JWT_SECRET=your-secret-key-here-make-it-long-and-secure-for-production
# Access JWT lifetime (seconds) and opaque refresh token TTL (days) for mobile "stay logged in"
# JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
# JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30

# ----- OpenAI (required for voice AI food/activity/cycle endpoints) -----
# mvn spring-boot:run (local profile) loads this file at startup via spring.config.import.
# You can copy the same value from ~/.zshrc if you already export it there.
# OPENAI_API_KEY=sk-...

# ----- USDA FoodData Central (optional; improves voice food calorie accuracy) -----
# Free key: https://fdc.nal.usda.gov/api-key-signup.html
# USDA_API_KEY=

# ----- Google OAuth (optional; defaults exist in application.properties) -----
# GOOGLE_CLIENT_ID_IOS=
# GOOGLE_CLIENT_ID_ANDROID=

# ----- Apple Sign In (required for Sign in with Apple) -----
# Get these from: https://developer.apple.com → Certificates, Identifiers & Profiles → Identifiers
#
# At least one of the following must be set so the backend can validate the "aud" claim in the Apple JWT.
#
# iOS: Your App ID / Bundle ID (e.g. com.yourcompany.healthapp)
APPLE_CLIENT_ID_IOS=

# Android/Web: Services ID from Apple (only if you use Sign in with Apple on Android or Web)
# APPLE_CLIENT_ID_ANDROID=
# APPLE_CLIENT_ID_WEB=

# Optional fallback used when platform-specific ID is not set
# APPLE_CLIENT_ID=

# ----- Apple Sign In dev options -----
# Expo Go returns Apple token audience as "host.exp.Exponent".
# Spring Boot does not read .env automatically — export vars before mvn, or use IDE env, OR rely on
# application-local.properties (active when spring.profiles.active=local; mvn spring-boot:run sets it).
# Enable ONLY for local development if you test Apple login via Expo Go. Keep false/unset in production.
# APPLE_ALLOW_EXPO_GO_AUDIENCE=false
# APPLE_EXPO_GO_AUDIENCE=host.exp.Exponent
#
# Optional extra audience allowlist (comma-separated), dev use only.
# APPLE_ALLOWED_AUDIENCES=
