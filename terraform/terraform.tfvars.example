# Example Terraform Variables
# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control if it contains real secrets

aws_region = "us-east-1"
db_password = "CHANGE_ME_SECURE_PASSWORD"
jwt_secret = "CHANGE_ME_JWT_SECRET"
environment = "production"  # or "staging" or "development"

# Apple Sign In (set at least iOS; Bundle ID)
apple_client_id_ios = "com.prod.thanafit"
# Optional fallback (often same as iOS Bundle ID if you only support iOS)
apple_client_id = "com.prod.thanafit"
# Optional (only if you support Apple Sign In on Android/Web)
# apple_client_id_android = ""
# apple_client_id_web = ""

# MVP Cost Optimizations (uncomment to reduce costs)
# ecs_desired_count = 1  # Reduced from 2 for MVP (saves ~$18/month)
# rds_backup_retention_days = 1  # Reduced from 7 for MVP (saves ~$0.15/month)

# Production settings (defaults)
# ecs_desired_count = 2  # Use 2 tasks for production redundancy
# enable_rds_backups = true
# rds_backup_retention_days = 7  # 7 days retention for production

